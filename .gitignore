# Environment — never commit API keys
.env

# Raw reviews — contains temporary review body text
# Generated by scraper.py, consumed by categorize.py, then discarded
data/reviews_raw.csv

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
pip-log.txt

# Virtual environments
env/
.env
venv/
.venv/
ENV/

# Streamlit secrets (if used instead of .env)
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo